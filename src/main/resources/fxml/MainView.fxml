<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="450.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.listacomprainterfacesev.controller.MainController">
   <top>
      <VBox alignment="CENTER" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="title-label" text="Mi Lista de la Compra" />
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <TextField fx:id="txtProducto" onAction="#onAgregarProducto" promptText="Escribe un producto..." styleClass="text-field" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#onAgregarProducto" styleClass="button, button-add" text="Añadir" />
               </children>
            </HBox>
            <Label fx:id="lblMensaje" textFill="#e74c3c" />
         </children>
         <BorderPane.margin>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
         </BorderPane.margin>
      </VBox>
   </top>
   <center>
      <ListView fx:id="ListViewProductos" prefHeight="200.0" prefWidth="200.0" styleClass="list-view" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets left="20.0" right="20.0" />
         </BorderPane.margin>
      </ListView>
   </center>
   <bottom>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Label fx:id="lblTotalProductos" styleClass="total-label" text="Total: 0" HBox.hgrow="ALWAYS">
                  </Label>
                  <Button fx:id="btnVaciar" mnemonicParsing="false" onAction="#onVaciarLista" styleClass="button, button-clear" text="Vaciar Lista" />
               </children>
            </HBox>
         </children>
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="15.0" />
         </BorderPane.margin>
      </VBox>
   </bottom>
</BorderPane>
